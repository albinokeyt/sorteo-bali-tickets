# ============================================================
#  CONFIGURACIÓN DEL SISTEMA DE TICKETS
#  Copia este archivo a ".env" y rellena tus valores reales.
# ============================================================

# --- Puerto público de la API / web ---
API_PORT=3000

# --- URL pública donde queda accesible la app (sin barra final) ---
# Es la URL que verán los clientes en el email y donde cargan las imágenes de ticket.
# Déjalo VACÍO para que la app detecte el dominio sola (EasyPanel o Caddy/VPS).
PUBLIC_URL=

# Solo VPS con Caddy: tu dominio (Caddy saca el SSL automático).
# Para probar por IP sin dominio usa ":80".
SITE_ADDRESS=tickets.tudominio.com

# --- Base de datos (docker-compose ya las inyecta; cámbialas en producción) ---
POSTGRES_USER=tickets
POSTGRES_PASSWORD=cambia-esta-clave
POSTGRES_DB=tickets

# ============================================================
#  BREVO (envío de emails)
#  Saca la API key en: Brevo > SMTP & API > API Keys
# ============================================================
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# NOTA: el remitente, nombre, asunto, preview y el HTML del email se editan
# desde el PANEL ADMIN (/admin) sin redesplegar. Estos valores son solo los
# INICIALES (se siembran la primera vez que arranca).
EMAIL_FROM=tickets@tudominio.com         # debe estar verificado en Brevo
EMAIL_FROM_NAME=Movimiento Real
EMAIL_SUBJECT=🎫 {{name}}, tu Ticket Dorado para Bali ya está aquí
EMAIL_PREHEADER=Tu Guía está lista y tienes {{count}} ticket(s) en el sorteo.
WHATSAPP_URL=https://wa.me/34919930715

# Velocidad de envío: emails por segundo que el worker manda a Brevo.
# Brevo aguanta bastante; ajusta según tu plan. 10 es seguro para empezar.
EMAIL_RATE_PER_SEC=10
# Reintentos por email si falla (con espera exponencial)
EMAIL_MAX_ATTEMPTS=4

# ============================================================
#  WEBHOOK DE GHL (GoHighLevel)
# ============================================================
# Token secreto: GHL debe mandarlo en el header  X-Webhook-Token  (o ?token= en la URL).
# Sirve para que nadie más pueda crear tickets falsos. Inventa una cadena larga.
WEBHOOK_SECRET=pon-aqui-un-secreto-largo-y-aleatorio

# Mapeo de campos del payload de GHL -> nuestro sistema.
# (soporta rutas con punto, ej: "customData.TkComprados"). Ya cuadrado con
# el webhook real del Sorteo Bali de Jorge Darek.
GHL_FIELD_EMAIL=email
GHL_FIELD_NAME=full_name
GHL_FIELD_QUANTITY=customData.TkComprados
GHL_FIELD_LINK=customData.LinkAcceso
# ID único de compra. GHL NO lo manda por defecto -> si este campo no existe en
# el payload, el sistema genera una clave determinista del payload (dedup de
# reintentos). Para idempotencia 100% (caso "compran 1 y luego 35"), añade en el
# webhook de GHL un customData "purchase_id" con un valor único por compra
# (ej. {{order.id}} / {{transaction.id}} / id de pago).
GHL_FIELD_ORDER_ID=customData.purchase_id
# Producto comprado (opcional) -> variable {{product}} del email. Déjalo vacío
# si no quieres mapearlo (se usará el nombre del sorteo).
GHL_FIELD_PRODUCT=
# Slug del sorteo al que entran las compras de este webhook (debe existir en la tabla raffles)
DEFAULT_RAFFLE_SLUG=viaje-bali

# ============================================================
#  PANEL ADMIN
# ============================================================
# Clave para entrar al panel /admin
ADMIN_PASSWORD=cambia-esta-clave-admin
# Secreto para firmar la sesión del admin (cadena larga aleatoria)
SESSION_SECRET=otro-secreto-largo-y-aleatorio

# ============================================================
#  TICKET (datos escritos sobre tu plantilla: Nombre, Correo, #Número)
# ============================================================
# Ruta de tu plantilla LIMPIA dentro del contenedor (la pones en ./assets).
TICKET_TEMPLATE=/app/assets/ticket-template.png

# Formato de la imagen del ticket. jpeg = ~40x más ligero que png (recomendado).
# Con jpeg + 1000px, cada ticket pesa ~80 KB (10.000 ≈ 0.8 GB en vez de 35 GB).
TICKET_FORMAT=jpeg
TICKET_QUALITY=82
TICKET_OUTPUT_WIDTH=1000   # ancho en px (0 = tamaño original de la plantilla)

# Fuente y estilo del texto
TICKET_FONT=DejaVu Serif, serif
TICKET_TEXT_COLOR=#462303
TICKET_TEXT_ANCHOR=middle          # start | middle | end (middle = centrado)
TICKET_MAX_WIDTH=880               # si un email es más largo, se reduce la fuente sola

# Línea fija de anuncio (déjala vacía para ocultarla).
TICKET_ANNOUNCE=GANADOR/GANADORA VIERNES 3 DE JULIO 2026
TICKET_ANNOUNCE_Y=572
TICKET_ANNOUNCE_SIZE=24

# Posición (px, origen arriba-izquierda) y tamaño de cada campo.
# Orden en el ticket: anuncio · Ticket #número · (divisor) · Nombre · Correo
# Medidos para la plantilla VIAJE A BALI v2 (1672x941).
# Si cambias de plantilla, ábrela en /t/<numero>.jpg y ajústalos.
TICKET_NUMBER_X=836
TICKET_NUMBER_Y=618
TICKET_NUMBER_SIZE=36
TICKET_NUMBER_PREFIX=Ticket: #     # queda "Ticket: #777"
TICKET_NUMBER_COLOR=#462303

# Línea combinada: "Nombre | Correo"
TICKET_CONTACT_X=836
TICKET_CONTACT_Y=692
TICKET_CONTACT_SIZE=26
TICKET_CONTACT_SEP=  |             # separador entre nombre y correo
